{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/network-security-integrated-scanner/findings.schema.json",
  "title": "Network Security Integrated Scanner findings",
  "type": "object",
  "required": ["schema_version", "assessment", "coverage", "findings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "assessment": {
      "type": "object",
      "required": ["mode", "generated_at"],
      "additionalProperties": true,
      "properties": {
        "mode": {"enum": ["external", "internal", "both", "forensics"]},
        "generated_at": {"type": "string"}
      }
    },
    "coverage": {
      "type": "object",
      "required": ["completed", "total", "gaps"],
      "additionalProperties": false,
      "properties": {
        "completed": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0},
        "gaps": {"type": "array", "items": {"type": "string"}}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id", "source", "asset", "component", "title", "severity",
          "status", "confidence", "identifiers", "evidence_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {"type": "string", "pattern": "^NSIS-[A-F0-9]{12}$"},
          "source": {"type": "string", "minLength": 1},
          "asset": {"type": "string", "minLength": 1},
          "component": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "severity": {"enum": ["critical", "high", "medium", "low", "info", "unknown"]},
          "status": {"enum": ["confirmed", "probable", "not-reproduced", "not-assessable"]},
          "confidence": {"enum": ["high", "medium", "low"]},
          "identifiers": {"type": "array", "items": {"type": "string"}},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "description": {"type": "string"},
          "exposure_conditions": {"type": "array", "items": {"type": "string"}},
          "impact": {"type": "string"},
          "remediation": {"type": "string"},
          "retest_method": {"type": "string"},
          "baseline_mappings": {"type": "array", "items": {"type": "string"}},
          "related_finding_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}

