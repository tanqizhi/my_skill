{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/network-security-integrated-scanner/report-findings.schema.json",
  "title": "Canonical vulnerability report import",
  "type": "object",
  "required": ["schema_version", "findings"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["report_id", "title", "target", "source_ref"],
        "additionalProperties": false,
        "properties": {
          "report_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "target": {"type": "string", "minLength": 1},
          "port": {"type": "integer", "minimum": 1, "maximum": 65535},
          "protocol": {"type": "string"},
          "url": {"type": "string", "format": "uri"},
          "vulnerability_id": {"type": "string"},
          "source_ref": {"type": "string", "minLength": 1},
          "verification_method": {"type": "string"}
        },
        "anyOf": [
          {"required": ["url"]},
          {"required": ["port", "protocol"]}
        ]
      }
    }
  }
}
